    <!--
      ToolbarControl (by linuxgurugamer, https://github.com/linuxgurugamer/ToolbarControl) lets a
      single button show on either Blizzy's Toolbar or the stock ApplicationLauncher, whichever the
      user has. It is NOT bundled with KSP, so these two files must be downloaded separately and
      placed at GameData\000_ToolbarControl\Plugins\ (the standard shared location every mod using
      ToolbarControl points at) before this project will build. Until then, comment these two
      References and ToolbarButton.cs's ToolbarControl usage back out to build with stock-only
      support instead.
    -->
    <Reference Include="ToolbarControl">
      <HintPath>$(KSPDIR)\GameData\001_ToolbarControl\Plugins\ToolbarControl.dll</HintPath>
      <Private>False</Private>
    </Reference>
